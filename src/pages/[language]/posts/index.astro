---
import { getPosts, PostClass, type CollectivePostProperties } from '@lib/posts';
import { LANGUAGES } from '@lib/languages';
import ItemsListPage from '@layouts/ItemsListPage.astro';
import type { Item } from '@components/ItemList.astro';

interface Props {
    items: Item[]
}

export async function getStaticPaths() {
    const posts = await getPosts();
    return Object.entries(LANGUAGES).flatMap(([_, language]) => {
        const postsByLanguage = posts.filter((post) => post.language.is(language));
        return {
            params: { language: language.getCode() },
            props: { items: postsByLanguage }
        }
    })
}

const { language } = Astro.params;
const languageObject = LANGUAGES[language];
const { items } = Astro.props;

const i18nVersions: Item[] = Object.entries(LANGUAGES)
    .filter(([code, _]) => code !== language)
    .map(([code, language]) => ({
        title: language.getDisplayName(),
        path: `/${code}/posts/`,
        languageCode: code,
    }));
---
<ItemsListPage 
    title={languageObject.getTranslation("all_posts")}
    items={items}
    i18nVersions={i18nVersions}
    language={language} />