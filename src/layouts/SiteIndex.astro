---
import Basic from "@layouts/Basic.astro"
import myImage from "@assets/images/me-jan-2026-charleston-sc.jpeg"

import { SITE_TITLE } from "@lib/constants"

---
<Basic title={SITE_TITLE}>
    <header>
        <h1 class="font-monospace">{SITE_TITLE}</h1>
    </header>
    <div class="homepage-main">
        <slot />
        <div class="homepage-photo-container">
            <img
                src={myImage.src}
                alt="A photo of me taken in January 2026 in Charleston, South Carolina."
                loading="lazy"
                decoding="async"
                style="
                width: 14rem; 
                height: auto; 
                box-shadow: 0 0 0.1rem rgba(0, 0, 0, 0.2);
                "
            />
            <figcaption style="margin: 0.5rem 0; font-size: 14px;">2026/01 @ Charleston, South Carolina</figcaption>
        </div>
    </div>
</Basic>